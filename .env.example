# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of this Next.js app (used for metadata, OG, and CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── API ──────────────────────────────────────────────────────────────────────
# Backend REST API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# WebSocket server URL
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Name of the HTTP-only cookie storing the access token
NEXT_PUBLIC_AUTH_COOKIE_NAME=auth_token

# Name of the HTTP-only cookie storing the refresh token
NEXT_PUBLIC_REFRESH_COOKIE_NAME=refresh_token

# ─── Multi-tenant ─────────────────────────────────────────────────────────────
# Tenant resolution strategy: 'subdomain' | 'path' | 'header'
NEXT_PUBLIC_TENANT_MODE=subdomain

# Root domain used for subdomain extraction in middleware
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ─── i18n ─────────────────────────────────────────────────────────────────────
# Default locale for the application
NEXT_PUBLIC_DEFAULT_LOCALE=uz

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Enable AI-powered features (chat assistant, auto-grading)
NEXT_PUBLIC_FEATURE_AI=false

# Enable real-time notifications via WebSocket
NEXT_PUBLIC_FEATURE_REALTIME=true

# Enable offline mode (PWA service worker)
NEXT_PUBLIC_FEATURE_OFFLINE=false

# ─── Analytics ────────────────────────────────────────────────────────────────
# Optional: PostHog / Plausible / Mixpanel key
NEXT_PUBLIC_ANALYTICS_KEY=

# ─── Sentry ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Storage ──────────────────────────────────────────────────────────────────
# CDN / storage base URL for uploaded files
NEXT_PUBLIC_STORAGE_URL=http://localhost:4000/uploads

# ─── Playwright E2E ───────────────────────────────────────────────────────────
# Base URL used by Playwright tests
PLAYWRIGHT_BASE_URL=http://localhost:3000
